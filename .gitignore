/data/**/*.zarr/
/data/**/*.nc
/data/**/*.h5
/data/**/*.hdf
/data/**/*.hdf5
/data/**/*.tif
/data/**/*.tiff
/data/**/*.mat
/data/**/*.log

# Generated workflow outputs
/outputs/
/examples/outputs/

